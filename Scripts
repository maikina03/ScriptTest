local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local gui = Instance.new("ScreenGui")
gui.Parent = playerGui

local container = Instance.new("Frame")
container.Size = UDim2.new(1,0,1,0)
container.BackgroundTransparency = 1
container.Parent = gui

local baseX, baseY = 0.33, 0.8
local scripts = {""}
local index = 1

-- BOTÓN CON BORDE
local function crearBotonConBorde(size, pos, text)
	local borde = Instance.new("Frame")
	borde.Size = UDim2.new(size.X.Scale, size.X.Offset+4, size.Y.Scale, size.Y.Offset+4)
	borde.Position = UDim2.new(pos.X.Scale, pos.X.Offset-2, pos.Y.Scale, pos.Y.Offset-2)
	borde.BorderSizePixel = 0
	borde.Parent = container
	Instance.new("UICorner", borde).CornerRadius = UDim.new(0,12)

	local btn = Instance.new("TextButton")
	btn.Size = size
	btn.Position = pos
	btn.Text = text
	btn.TextSize = 16
	btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Parent = container
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0,12)

	return btn, borde
end

-- BOTONES
local destroyBtn, destroyBorde = crearBotonConBorde(UDim2.new(0,60,0,30), UDim2.new(baseX,-100,baseY,-40), "X")
local draggableBtn, dragBorde = crearBotonConBorde(UDim2.new(0,60,0,30), UDim2.new(baseX,-30,baseY,-40), "Drag")
local autoBtn, autoBorde = crearBotonConBorde(UDim2.new(0,60,0,30), UDim2.new(baseX,40,baseY,-40), "Auto")
local button, mainBorde = crearBotonConBorde(UDim2.new(0,200,0,60), UDim2.new(baseX,-100,baseY,0), "OFF")
local left, leftBorde = crearBotonConBorde(UDim2.new(0,50,0,60), UDim2.new(baseX,120,baseY,0), "<")
local right, rightBorde = crearBotonConBorde(UDim2.new(0,50,0,60), UDim2.new(baseX,390,baseY,0), ">")

-- TEXTBOX
local codeBox = Instance.new("TextBox")
codeBox.Parent = container
codeBox.Size = UDim2.new(0,200,0,60)
codeBox.Position = UDim2.new(baseX,180,baseY,0)
codeBox.BackgroundColor3 = Color3.fromRGB(0,0,0)
codeBox.Text = ""
codeBox.TextTransparency = 1
codeBox.ClearTextOnFocus = false
Instance.new("UICorner",codeBox).CornerRadius = UDim.new(0,12)

local strokeBox = Instance.new("UIStroke", codeBox)
strokeBox.Thickness = 2

-- LABEL
local label = Instance.new("TextLabel")
label.Parent = container
label.Size = codeBox.Size
label.Position = codeBox.Position
label.BackgroundTransparency = 1
label.Text = "codigo 1"
label.TextSize = 16
label.ZIndex = codeBox.ZIndex + 1

local function actualizarLabel()
	label.Text = "codigo "..index
end

-- 🔥 FIX DEFINITIVO INPUT INVISIBLE
codeBox.Text = ""

codeBox.Focused:Connect(function()
	codeBox.Text = ""
end)

codeBox:GetPropertyChangedSignal("Text"):Connect(function()
	if codeBox.Text ~= "" then
		scripts[index] = scripts[index] .. codeBox.Text
		codeBox.Text = "" -- borra al escribir
	end
end)

codeBox.FocusLost:Connect(function()
	codeBox.Text = "" -- 🔥 borra al salir
end)

-- CAMBIO SLOT
local function cambiarSlot(d)
	index += d
	if index < 1 then index = #scripts
	elseif index > #scripts then table.insert(scripts,"") end
	actualizarLabel()
end

left.MouseButton1Click:Connect(function() cambiarSlot(-1) end)
right.MouseButton1Click:Connect(function() cambiarSlot(1) end)

-- AUTO
local auto = false
local direction = 1

autoBtn.MouseButton1Click:Connect(function()
	auto = not auto
end)

task.spawn(function()
	while true do
		if auto and #scripts > 1 then
			task.wait(5)
			cambiarSlot(direction)
			if index == #scripts then direction = -1
			elseif index == 1 then direction = 1 end
		else
			task.wait(0.5)
		end
	end
end)

-- DRAG
local draggable = false
draggableBtn.MouseButton1Click:Connect(function()
	draggable = not draggable
end)

local dragging = false
local dragStart

UserInputService.TouchStarted:Connect(function(i)
	if draggable then dragging = true dragStart = i.Position end
end)

UserInputService.TouchMoved:Connect(function(i)
	if dragging then
		local delta = i.Position - dragStart
		container.Position += UDim2.new(0,delta.X,0,delta.Y)
		dragStart = i.Position
	end
end)

UserInputService.TouchEnded:Connect(function()
	dragging = false
end)

-- X BOTÓN
local visible = true
local lastClick = 0

destroyBtn.MouseButton1Click:Connect(function()
	local now = tick()

	if now - lastClick < 0.3 then
		gui:Destroy()
	else
		visible = not visible
		for _,v in pairs(container:GetChildren()) do
			if v ~= destroyBtn and v ~= destroyBorde then
				v.Visible = visible
			end
		end
	end

	lastClick = now
end)

-- ON/OFF
local activo, conexion = false, nil

button.MouseButton1Click:Connect(function()
	activo = not activo

	if activo then
		button.Text = "ON"
		conexion = RunService.Heartbeat:Connect(function()
			local codigo = scripts[index]
			if codigo ~= "" then
				local f = loadstring(codigo)
				if f then pcall(f) end
			end
		end)
	else
		button.Text = "OFF"
		if conexion then conexion:Disconnect() end
	end
end)

-- RGB
task.spawn(function()
	local h = 0
	while true do
		h += 0.01
		if h > 1 then h = 0 end
		local c = Color3.fromHSV(h,1,1)

		button.TextColor3 = c
		left.TextColor3 = c
		right.TextColor3 = c
		destroyBtn.TextColor3 = c
		label.TextColor3 = c

		draggableBtn.TextColor3 = draggable and Color3.fromRGB(0,255,0) or c
		autoBtn.TextColor3 = auto and Color3.fromRGB(0,255,0) or c

		mainBorde.BackgroundColor3 = c
		leftBorde.BackgroundColor3 = c
		rightBorde.BackgroundColor3 = c
		destroyBorde.BackgroundColor3 = c
		dragBorde.BackgroundColor3 = c
		autoBorde.BackgroundColor3 = c
		strokeBox.Color = c

		task.wait()
	end
end)
