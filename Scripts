-- DRAG
local draggable = false
draggableBtn.MouseButton1Click:Connect(function()
	draggable = not draggable
end)

local dragging = false
local dragStart

UserInputService.TouchStarted:Connect(function(i)
	if draggable then dragging = true dragStart = i.Position end
end)

UserInputService.TouchMoved:Connect(function(i)
	if dragging then
		local delta = i.Position - dragStart
		container.Position += UDim2.new(0,delta.X,0,delta.Y)
		dragStart = i.Position
	end
end)

UserInputService.TouchEnded:Connect(function()
	dragging = false
end)

-- X
local visible = true
local lastClick = 0

destroyBtn.MouseButton1Click:Connect(function()
	local now = tick()
	if now - lastClick < 0.3 then
		task.delay(1, function()
			gui:Destroy()
		end)
	else
		visible = not visible
		for _,v in pairs(container:GetChildren()) do
			if v ~= destroyBtn and v ~= destroyBorde then
				v.Visible = visible
			end
		end
	end
	lastClick = now
end)

-- ABRIR PACKS (MISMO)
local abriendoPacks = false

abrirPacksBtn.MouseButton1Click:Connect(function()
	if abriendoPacks then return end
	abriendoPacks = true

	task.spawn(function()
		local character = player.Character or player.CharacterAdded:Wait()
		local humanoid = character:WaitForChild("Humanoid")
		local root = character:WaitForChild("HumanoidRootPart")

		local plot = workspace:WaitForChild("Plots"):WaitForChild("1")
		local packsFolder = plot:WaitForChild("Packs")
		local abiertos = {}

		while true do
			task.wait(0.1)

			local siguiente, prompt, pos
			local distMin = math.huge

			for _, packId in pairs(packsFolder:GetChildren()) do
				for _, pack in pairs(packId:GetChildren()) do
					if not abiertos[pack] then
						local p = pack:FindFirstChildOfClass("ProximityPrompt", true)
						if p and p.Parent:IsA("BasePart") then
							local d = (root.Position - p.Parent.Position).Magnitude
							if d < distMin then
								distMin = d
								siguiente = pack
								prompt = p
								pos = p.Parent.Position
							end
						end
					end
				end
			end

			if siguiente then
				humanoid:MoveTo(pos)
				if distMin <= 5 then
					fireproximityprompt(prompt)
					abiertos[siguiente] = true
					task.wait(0.5)
				end
			else
				break
			end
		end

		abriendoPacks = false
	end)
end)

