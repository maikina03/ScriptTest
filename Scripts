local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local gui = Instance.new("ScreenGui")
gui.Parent = playerGui

local container = Instance.new("Frame")
container.Size = UDim2.new(1,0,1,0)
container.BackgroundTransparency = 1
container.Parent = gui

-- Base
local baseX, baseY = 0.33, 0.8

-- Sistema de slots
local scripts = {""}
local index = 1

-- ── BOTÓN X ──
local destroyBtn = Instance.new("TextButton")
destroyBtn.Parent = container
destroyBtn.Size = UDim2.new(0,60,0,30)
destroyBtn.Position = UDim2.new(baseX,-100,baseY,-40)
destroyBtn.Text = "X"
destroyBtn.TextScaled = true
destroyBtn.BackgroundColor3 = Color3.fromRGB(0,0,0)
destroyBtn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner",destroyBtn).CornerRadius = UDim.new(0,10)

local lastClick = 0
destroyBtn.MouseButton1Click:Connect(function()
	local time = tick()
	if time - lastClick < 0.25 then
		gui:Destroy()
	end
	lastClick = time
end)

-- ── BOTÓN DRAG ──
local draggableBtn = Instance.new("TextButton")
draggableBtn.Parent = container
draggableBtn.Size = UDim2.new(0,60,0,30)
draggableBtn.Position = UDim2.new(baseX,-30,baseY,-40)
draggableBtn.Text = "Drag"
draggableBtn.TextScaled = true
draggableBtn.BackgroundColor3 = Color3.fromRGB(0,0,0)
draggableBtn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner",draggableBtn).CornerRadius = UDim.new(0,10)

local draggable = false
draggableBtn.MouseButton1Click:Connect(function()
	draggable = not draggable
end)

-- ── BOTÓN AUTO ──
local autoBtn = Instance.new("TextButton")
autoBtn.Parent = container
autoBtn.Size = UDim2.new(0,60,0,30)
autoBtn.Position = UDim2.new(baseX,40,baseY,-40)
autoBtn.Text = "Auto"
autoBtn.TextScaled = true
autoBtn.BackgroundColor3 = Color3.fromRGB(0,0,0)
autoBtn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner",autoBtn).CornerRadius = UDim.new(0,10)

local auto = false
local direction = 1

autoBtn.MouseButton1Click:Connect(function()
	auto = not auto
end)

-- ── BOTÓN ON/OFF ──
local button = Instance.new("TextButton")
button.Parent = container
button.Size = UDim2.new(0,200,0,60)
button.Position = UDim2.new(baseX,-100,baseY,0)
button.Text = "OFF"
button.TextScaled = true
button.BackgroundColor3 = Color3.fromRGB(0,0,0)
button.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner",button).CornerRadius = UDim.new(0,20)

local stroke = Instance.new("UIStroke",button)
stroke.Thickness = 3

-- Flechas
local left = Instance.new("TextButton")
left.Parent = container
left.Size = UDim2.new(0,50,0,60)
left.Position = UDim2.new(baseX,120,baseY,0)
left.Text = "<"
left.TextScaled = true
left.BackgroundColor3 = Color3.fromRGB(0,0,0)
left.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner",left).CornerRadius = UDim.new(0,15)

local right = Instance.new("TextButton")
right.Parent = container
right.Size = UDim2.new(0,50,0,60)
right.Position = UDim2.new(baseX,390,baseY,0)
right.Text = ">"
right.TextScaled = true
right.BackgroundColor3 = Color3.fromRGB(0,0,0)
right.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner",right).CornerRadius = UDim.new(0,15)

-- ── CAJA DE TEXTO ──
local codeBox = Instance.new("TextBox")
codeBox.Parent = container
codeBox.Size = UDim2.new(0,200,0,60)
codeBox.Position = UDim2.new(baseX,180,baseY,0)
codeBox.BackgroundColor3 = Color3.fromRGB(0,0,0)
codeBox.TextColor3 = Color3.new(1,1,1)
codeBox.TextScaled = true
codeBox.ClearTextOnFocus = false
codeBox.TextTransparency = 1
Instance.new("UICorner",codeBox).CornerRadius = UDim.new(0,20)

-- Label
local label = Instance.new("TextLabel")
label.Parent = container
label.Size = codeBox.Size
label.Position = codeBox.Position
label.BackgroundTransparency = 1
label.TextColor3 = Color3.new(1,1,1)
label.TextScaled = true
label.TextStrokeTransparency = 0.5
label.Text = "codigo 1"
label.Active = false
label.ZIndex = codeBox.ZIndex + 1

local function actualizarLabel()
	label.Text = "codigo "..index
end

-- Eventos caja
codeBox.Focused:Connect(function()
	codeBox.TextTransparency = 0
	codeBox.Text = scripts[index]
end)

codeBox.FocusLost:Connect(function()
	scripts[index] = codeBox.Text
	codeBox.TextTransparency = 1
end)

-- Flechas
local function cambiarSlot(direccion)
	scripts[index] = codeBox.Text
	index += direccion
	
	if index < 1 then
		index = #scripts
	elseif index > #scripts then
		table.insert(scripts,"")
	end
	
	actualizarLabel()
	codeBox.Text = scripts[index]
end

left.MouseButton1Click:Connect(function()
	cambiarSlot(-1)
end)

right.MouseButton1Click:Connect(function()
	cambiarSlot(1)
end)

-- AUTO LOOP
task.spawn(function()
	while true do
		if auto and #scripts > 1 then
			task.wait(5)
			
			scripts[index] = codeBox.Text
			index += direction
			
			if index >= #scripts then
				index = #scripts
				direction = -1
			elseif index <= 1 then
				index = 1
				direction = 1
			end
			
			actualizarLabel()
			codeBox.Text = scripts[index]
		else
			task.wait(0.5)
		end
	end
end)

-- RGB GLOBAL
task.spawn(function()
	local hue = 0
	while true do
		hue += 0.01
		if hue > 1 then hue = 0 end
		local color = Color3.fromHSV(hue,1,1)

		button.TextColor3 = color
		stroke.Color = color
		left.TextColor3 = color
		right.TextColor3 = color
		label.TextColor3 = color

		destroyBtn.TextColor3 = color
		draggableBtn.TextColor3 = color
		autoBtn.TextColor3 = color

		task.wait()
	end
end)

-- EJECUCIÓN
local activo = false
local conexion

button.MouseButton1Click:Connect(function()
	activo = not activo
	
	if activo then
		button.Text = "ON"
		conexion = RunService.Heartbeat:Connect(function()
			local codigo = scripts[index]
			if codigo ~= "" then
				local func = loadstring(codigo)
				if func then pcall(func) end
			end
		end)
	else
		button.Text = "OFF"
		if conexion then conexion:Disconnect() end
	end
end)

-- DRAG
local dragging = false
local dragStart, startPos

local function startDrag(pos)
	if draggable then
		dragging = true
		dragStart = pos
		startPos = container.Position
	end
end

local function updateDrag(pos)
	if dragging then
		local delta = pos - dragStart
		container.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end

local function endDrag()
	dragging = false
end

container.InputBegan:Connect(function(input)
	if draggable and input.UserInputType == Enum.UserInputType.MouseButton1 then
		startDrag(input.Position)
	end
end)

container.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement then
		updateDrag(input.Position)
	end
end)

UserInputService.TouchStarted:Connect(function(input)
	if draggable then startDrag(input.Position) end
end)

UserInputService.TouchMoved:Connect(function(input)
	updateDrag(input.Position)
end)

UserInputService.TouchEnded:Connect(function()
	endDrag()
end)
